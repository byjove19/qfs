<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" type="image/png" href="/images/logo.png">

    <style>
        /* === USER'S ORIGINAL STYLING PRESERVED === */
        :root {
            --tg-body-font-family: 'Inter', sans-serif;
            --tg-heading-font-family: 'Inter', sans-serif;
            --tg-body-font-size: 16px;
            --tg-body-color: #9E9E9E;
            --tg-heading-color: #ffffff;
            --tg-theme-primary: #4b59f5;
            --tg-theme-primary-hover: #3a49e5;
            --tg-color-dark: #0C0C0C;
            --tg-color-dark-2: #000000;
            --tg-color-dark-3: #262626;
            --tg-border-1: #363636;
            --tg-shadow: 0 4px 12px rgba(0, 0, 0, 0.1);
            --tg-transition: all 0.3s ease;
            --tg-success: #00E676;
            --tg-warning: #ffaa00;
            --tg-danger: #ff4466;
            --tg-info: #00b0ff;
        }

        [data-theme="light"] {
            --tg-body-color: #5a5a5a;
            --tg-heading-color: #1a1a1a;
            --tg-color-dark: #f8f9fa;
            --tg-color-dark-2: #ffffff;
            --tg-color-dark-3: #e9ecef;
            --tg-border-1: #dee2e6;
            --tg-shadow: 0 4px 12px rgba(0, 0, 0, 0.05);
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: var(--tg-body-font-family);
            font-size: var(--tg-body-font-size);
            color: var(--tg-body-color);
            background: var(--tg-color-dark);
            transition: var(--tg-transition);
            line-height: 1.6;
        }

        .admin-wrapper {
            display: flex;
            min-height: 100vh;
        }

        /* Theme Toggle */
        .theme-toggle {
            position: fixed;
            top: 20px;
            right: 20px;
            width: 50px;
            height: 50px;
            background: var(--tg-color-dark-2);
            border: 1px solid var(--tg-border-1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            z-index: 1000;
            transition: var(--tg-transition);
            box-shadow: var(--tg-shadow);
        }

        .theme-toggle:hover {
            transform: scale(1.1);
            background: var(--tg-color-dark-3);
        }

        .theme-toggle svg {
            width: 24px;
            height: 24px;
            fill: var(--tg-heading-color);
            transition: var(--tg-transition);
        }

        /* Sidebar Styles */
        .admin-sidebar {
            width: 280px;
            background: var(--tg-color-dark-2);
            border-right: 1px solid var(--tg-border-1);
            display: flex;
            flex-direction: column;
            transition: var(--tg-transition);
            position: relative;
            z-index: 100;
            overflow: hidden;
        }

        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid var(--tg-border-1);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .logo-text {
            font-size: 24px;
            font-weight: 800;
            color: var(--tg-heading-color);
            text-decoration: none;
            letter-spacing: 2.5px;
            text-transform: uppercase;
            text-shadow: 0px 2px 4px rgba(0,0,0,0.1);
        }

        .sidebar-close {
            display: none;
            background: none;
            border: none;
            color: var(--tg-heading-color);
            font-size: 18px;
            cursor: pointer;
            padding: 5px;
            border-radius: 5px;
            transition: var(--tg-transition);
        }

        .sidebar-close:hover {
            background: var(--tg-color-dark-3);
        }

        .sidebar-nav {
            flex: 1;
            padding: 20px 0;
            overflow: hidden;
        }

        
        /* Hide scrollbars in sidebar */
        .admin-sidebar::-webkit-scrollbar,
        .sidebar-nav::-webkit-scrollbar {
            display: none;
        }

        .admin-sidebar,
        .sidebar-nav {
            -ms-overflow-style: none;
            scrollbar-width: none;
        }
.sidebar-nav ul {
            list-style: none;
        }

        .sidebar-nav li {
            margin-bottom: 5px;
        }

        .nav-link {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: var(--tg-body-color);
            text-decoration: none;
            transition: var(--tg-transition);
            border-left: 3px solid transparent;
            position: relative;
        }

        .nav-link:hover {
            background: var(--tg-color-dark-3);
            color: var(--tg-heading-color);
            transform: translateX(5px);
        }

        .nav-link.active {
            background: var(--tg-color-dark-3);
            color: var(--tg-theme-primary);
            border-left-color: var(--tg-theme-primary);
        }

        .nav-link i {
            width: 24px;
            margin-right: 12px;
            font-size: 16px;
            transition: var(--tg-transition);
        }

        .sidebar-footer {
            padding: 20px;
            border-top: 1px solid var(--tg-border-1);
        }

        .sidebar-footer .nav-link {
            padding: 10px 0;
            border-left: none;
        }

        /* Main Content Styles */
        .admin-main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            transition: var(--tg-transition);
        }

        .admin-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 30px;
            background: var(--tg-color-dark-2);
            border-bottom: 1px solid var(--tg-border-1);
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .sidebar-toggle {
            background: none;
            border: none;
            color: var(--tg-heading-color);
            font-size: 18px;
            cursor: pointer;
            padding: 8px;
            border-radius: 6px;
            transition: var(--tg-transition);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .sidebar-toggle:hover {
            background: var(--tg-color-dark-3);
            transform: rotate(90deg);
        }

        .admin-header h1 {
            font-size: 24px;
            font-weight: 700;
            color: var(--tg-heading-color);
        }

        .header-right {
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .admin-name {
            color: var(--tg-heading-color);
            font-weight: 500;
        }

        .badge {
            background: var(--tg-theme-primary);
            color: white;
            padding: 5px 12px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .admin-content {
            flex: 1;
            padding: 30px;
            overflow-y: auto;
        }

        /* Trust Wallet Specific Styles */
        .trust-stats-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }

        .trust-stat-card {
            background: var(--tg-color-dark-2);
            border-radius: 16px;
            padding: 25px;
            display: flex;
            align-items: center;
            box-shadow: var(--tg-shadow);
            transition: var(--tg-transition);
            border: 1px solid var(--tg-border-1);
            position: relative;
            overflow: hidden;
        }

        .trust-stat-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            width: 4px;
            height: 100%;
        }

        .trust-stat-card.total::before { background: var(--tg-theme-primary); }
        .trust-stat-card.connected::before { background: var(--tg-success); }
        .trust-stat-card.backedup::before { background: var(--tg-info); }
        .trust-stat-card.password::before { background: var(--tg-warning); }

        .trust-stat-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .trust-stat-icon {
            width: 60px;
            height: 60px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin-right: 15px;
            font-size: 24px;
            color: white;
        }

        .trust-stat-card.total .trust-stat-icon { background: linear-gradient(135deg, var(--tg-theme-primary), #6c63ff); }
        .trust-stat-card.connected .trust-stat-icon { background: linear-gradient(135deg, var(--tg-success), #00C853); }
        .trust-stat-card.backedup .trust-stat-icon { background: linear-gradient(135deg, var(--tg-info), #0091ea); }
        .trust-stat-card.password .trust-stat-icon { background: linear-gradient(135deg, var(--tg-warning), #ff6d00); }

        .trust-stat-info h3 {
            font-size: 28px;
            font-weight: 700;
            color: var(--tg-heading-color);
            margin-bottom: 5px;
            line-height: 1;
        }

        .trust-stat-info p {
            font-size: 13px;
            color: var(--tg-body-color);
            font-weight: 500;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        /* Filter Card */
        .filter-card {
            background: var(--tg-color-dark-2);
            border-radius: 16px;
            padding: 20px;
            margin-bottom: 25px;
            border: 1px solid var(--tg-border-1);
        }

        .filter-form {
            display: flex;
            gap: 15px;
            flex-wrap: wrap;
            align-items: end;
        }

        .filter-group {
            flex: 1;
            min-width: 200px;
        }

        .filter-group label {
            display: block;
            margin-bottom: 8px;
            color: var(--tg-heading-color);
            font-size: 14px;
            font-weight: 500;
        }

        .filter-input {
            width: 100%;
            padding: 12px 15px;
            background: var(--tg-color-dark-3);
            border: 1px solid var(--tg-border-1);
            border-radius: 10px;
            color: var(--tg-heading-color);
            font-size: 14px;
            transition: var(--tg-transition);
        }

        .filter-input:focus {
            outline: none;
            border-color: var(--tg-theme-primary);
            box-shadow: 0 0 0 3px rgba(75, 89, 245, 0.1);
        }

        .filter-btn {
            padding: 12px 25px;
            background: var(--tg-theme-primary);
            color: white;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--tg-transition);
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .filter-btn:hover {
            background: var(--tg-theme-primary-hover);
            transform: translateY(-2px);
        }

        .clear-btn {
            padding: 12px 20px;
            background: transparent;
            color: var(--tg-body-color);
            border: 1px solid var(--tg-border-1);
            border-radius: 10px;
            font-weight: 500;
            text-decoration: none;
            transition: var(--tg-transition);
        }

        .clear-btn:hover {
            background: var(--tg-color-dark-3);
            color: var(--tg-heading-color);
        }

        /* Table Styles */
        .card {
            background: var(--tg-color-dark-2);
            border-radius: 16px;
            box-shadow: var(--tg-shadow);
            margin-bottom: 30px;
            overflow: hidden;
            transition: var(--tg-transition);
            border: 1px solid var(--tg-border-1);
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 0, 0, 0.15);
        }

        .card-header {
            padding: 20px 25px;
            border-bottom: 1px solid var(--tg-border-1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            flex-wrap: wrap;
            gap: 15px;
        }

        .card-header h2 {
            font-size: 20px;
            font-weight: 600;
            color: var(--tg-heading-color);
        }

        .tg-btn {
            background: var(--tg-theme-primary);
            color: white;
            padding: 10px 20px;
            border-radius: 8px;
            text-decoration: none;
            font-size: 14px;
            font-weight: 500;
            transition: var(--tg-transition);
            border: none;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .tg-btn:hover {
            background: var(--tg-theme-primary-hover);
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(75, 89, 245, 0.3);
        }

        .tg-btn-outline {
            background: transparent;
            border: 1px solid var(--tg-border-1);
            color: var(--tg-heading-color);
        }

        .tg-btn-outline:hover {
            background: var(--tg-color-dark-3);
        }

        .card-body {
            padding: 0;
        }

        .table-responsive {
            overflow-x: auto;
        }

        .admin-table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1000px;
        }

        .admin-table th {
            text-align: left;
            padding: 15px 20px;
            font-weight: 600;
            color: var(--tg-heading-color);
            border-bottom: 1px solid var(--tg-border-1);
            background: var(--tg-color-dark-3);
            font-size: 13px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .admin-table td {
            padding: 18px 20px;
            border-bottom: 1px solid var(--tg-border-1);
            transition: var(--tg-transition);
            vertical-align: middle;
        }

        .admin-table tr:last-child td {
            border-bottom: none;
        }

        .admin-table tr:hover {
            background: var(--tg-color-dark-3);
            cursor: pointer;
        }

        .user-cell {
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .user-avatar {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--tg-theme-primary), #6c63ff);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            font-weight: 600;
            font-size: 16px;
            box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
        }

        .user-info strong {
            color: var(--tg-heading-color);
            display: block;
            font-weight: 600;
        }

        .user-info span {
            font-size: 13px;
            color: var(--tg-body-color);
        }

        .wallet-name {
            color: var(--tg-heading-color);
            font-weight: 600;
            font-size: 15px;
        }

        .wallet-address {
            font-family: 'Courier New', monospace;
            font-size: 12px;
            color: var(--tg-body-color);
            background: var(--tg-color-dark-3);
            padding: 4px 8px;
            border-radius: 4px;
            display: inline-block;
            margin-top: 4px;
            max-width: 150px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        /* Status Badges */
        .badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            border: 1px solid transparent;
        }

        .badge-connected {
            background: rgba(0, 230, 118, 0.1);
            color: var(--tg-success);
            border-color: rgba(0, 230, 118, 0.3);
        }

        .badge-disconnected {
            background: rgba(148, 163, 184, 0.1);
            color: #888;
            border-color: rgba(148, 163, 184, 0.3);
        }

        .badge-backedup {
            background: rgba(0, 176, 255, 0.1);
            color: var(--tg-info);
            border-color: rgba(0, 176, 255, 0.3);
        }

        .badge-notbackedup {
            background: rgba(245, 158, 11, 0.1);
            color: var(--tg-warning);
            border-color: rgba(245, 158, 11, 0.3);
        }

        /* Type Badge */
        .type-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            padding: 6px 12px;
            background: var(--tg-color-dark-3);
            border-radius: 6px;
            font-size: 12px;
            color: var(--tg-heading-color);
            border: 1px solid var(--tg-border-1);
        }

        .type-badge i {
            color: var(--tg-theme-primary);
        }

        /* Balance */
        .balance {
            font-family: 'Courier New', monospace;
            font-weight: 600;
            color: var(--tg-success);
            font-size: 13px;
        }

        /* Actions */
        .actions {
            display: flex;
            gap: 8px;
        }

        .btn-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: var(--tg-color-dark-3);
            border: 1px solid var(--tg-border-1);
            color: var(--tg-body-color);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all 0.3s;
        }

        .btn-icon:hover {
            background: var(--tg-theme-primary);
            color: white;
            border-color: var(--tg-theme-primary);
            transform: translateY(-2px);
        }

        .btn-icon.delete:hover {
            background: var(--tg-danger);
            border-color: var(--tg-danger);
        }

        /* View Button */
        .btn-view {
            padding: 8px 16px;
            background: var(--tg-theme-primary);
            color: white;
            border: none;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            transition: var(--tg-transition);
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        .btn-view:hover {
            background: var(--tg-theme-primary-hover);
            transform: translateY(-2px);
        }

        /* Empty State */
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: var(--tg-body-color);
        }

        .empty-state i {
            font-size: 64px;
            margin-bottom: 20px;
            opacity: 0.5;
        }

        /* Pagination */
        .pagination-container {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 20px 25px;
            border-top: 1px solid var(--tg-border-1);
        }

        .pagination-info {
            color: var(--tg-body-color);
            font-size: 14px;
        }

        .pagination {
            display: flex;
            gap: 5px;
        }

        .page-link {
            padding: 8px 14px;
            background: var(--tg-color-dark-3);
            border: 1px solid var(--tg-border-1);
            border-radius: 8px;
            color: var(--tg-heading-color);
            text-decoration: none;
            font-size: 14px;
            transition: all 0.3s;
        }

        .page-link:hover, .page-link.active {
            background: var(--tg-theme-primary);
            border-color: var(--tg-theme-primary);
            color: white;
        }

        /* Security Warning */
        .security-banner {
            background: linear-gradient(90deg, rgba(239, 68, 68, 0.1), rgba(245, 158, 11, 0.1));
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            padding: 16px 20px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 15px;
            color: var(--tg-warning);
            font-size: 14px;
        }

        .security-banner i {
            font-size: 24px;
        }

        .security-banner strong {
            color: var(--tg-danger);
        }

        /* Toast */
        .toast {
            position: fixed;
            bottom: 30px;
            right: 30px;
            background: var(--tg-color-dark-2);
            border: 1px solid var(--tg-border-1);
            border-radius: 12px;
            padding: 16px 24px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 10px 40px rgba(0,0,0,0.4);
            transform: translateX(400px);
            transition: transform 0.3s ease;
            z-index: 9999;
        }

        .toast.show {
            transform: translateX(0);
        }

        .toast-icon {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .toast.success .toast-icon { background: rgba(0, 230, 118, 0.2); color: var(--tg-success); }
        .toast.error .toast-icon { background: rgba(255, 68, 102, 0.2); color: var(--tg-danger); }

        .toast-content {
            color: var(--tg-heading-color);
            font-weight: 500;
        }

        /* === MODAL STYLES === */
        .modal-overlay {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(5px);
            display: flex;
            align-items: center;
            justify-content: center;
            z-index: 10000;
            opacity: 0;
            visibility: hidden;
            transition: all 0.3s ease;
        }

        .modal-overlay.active {
            opacity: 1;
            visibility: visible;
        }

        .modal-container {
            background: var(--tg-color-dark-2);
            border-radius: 16px;
            border: 1px solid var(--tg-border-1);
            width: 90%;
            max-width: 700px;
            max-height: 90vh;
            overflow-y: auto;
            transform: scale(0.9) translateY(20px);
            transition: all 0.3s ease;
            box-shadow: 0 25px 50px rgba(0, 0, 0, 0.5);
        }

        .modal-overlay.active .modal-container {
            transform: scale(1) translateY(0);
        }

        .modal-header {
            padding: 24px 30px;
            border-bottom: 1px solid var(--tg-border-1);
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: var(--tg-color-dark-3);
            border-radius: 16px 16px 0 0;
        }

        .modal-title {
            font-size: 20px;
            font-weight: 700;
            color: var(--tg-heading-color);
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .modal-title i {
            color: var(--tg-theme-primary);
        }

        .modal-close {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: var(--tg-color-dark-2);
            border: 1px solid var(--tg-border-1);
            color: var(--tg-body-color);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: var(--tg-transition);
            font-size: 16px;
        }

        .modal-close:hover {
            background: var(--tg-danger);
            color: white;
            border-color: var(--tg-danger);
        }

        .modal-body {
            padding: 30px;
        }

        .modal-section {
            margin-bottom: 24px;
        }

        .modal-section:last-child {
            margin-bottom: 0;
        }

        .section-title {
            font-size: 12px;
            font-weight: 700;
            color: var(--tg-theme-primary);
            text-transform: uppercase;
            letter-spacing: 1px;
            margin-bottom: 12px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .detail-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 16px;
        }

        .detail-item {
            background: var(--tg-color-dark);
            padding: 16px;
            border-radius: 10px;
            border: 1px solid var(--tg-border-1);
        }

        .detail-item.full-width {
            grid-column: 1 / -1;
        }

        .detail-label {
            font-size: 11px;
            color: var(--tg-body-color);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            margin-bottom: 6px;
            font-weight: 600;
        }

        .detail-value {
            font-size: 14px;
            color: var(--tg-heading-color);
            font-weight: 600;
            word-break: break-all;
        }

        .detail-value.mono {
            font-family: 'Courier New', monospace;
            font-size: 13px;
            background: rgba(0, 0, 0, 0.3);
            padding: 8px 12px;
            border-radius: 6px;
            border: 1px solid var(--tg-border-1);
        }

        .detail-value.secret {
            color: var(--tg-warning);
            background: rgba(255, 170, 0, 0.1);
            border-color: rgba(255, 170, 0, 0.3);
        }

        .modal-footer {
            padding: 20px 30px;
            border-top: 1px solid var(--tg-border-1);
            display: flex;
            justify-content: flex-end;
            gap: 12px;
            background: var(--tg-color-dark-3);
            border-radius: 0 0 16px 16px;
        }

        .modal-btn {
            padding: 12px 24px;
            border-radius: 8px;
            font-weight: 600;
            font-size: 14px;
            cursor: pointer;
            transition: var(--tg-transition);
            border: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

        .modal-btn-secondary {
            background: var(--tg-color-dark-2);
            color: var(--tg-heading-color);
            border: 1px solid var(--tg-border-1);
        }

        .modal-btn-secondary:hover {
            background: var(--tg-border-1);
        }

        .modal-btn-primary {
            background: var(--tg-theme-primary);
            color: white;
        }

        .modal-btn-primary:hover {
            background: var(--tg-theme-primary-hover);
        }

        .modal-btn-danger {
            background: var(--tg-danger);
            color: white;
        }

        .modal-btn-danger:hover {
            background: #ff3355;
        }

        .security-notice {
            background: rgba(239, 68, 68, 0.1);
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 8px;
            padding: 12px 16px;
            margin-bottom: 20px;
            display: flex;
            align-items: center;
            gap: 10px;
            color: var(--tg-warning);
            font-size: 13px;
        }

        .security-notice i {
            font-size: 16px;
        }

        /* ========== RESPONSIVE FIXES ========== */

        /* Tablet (768px - 1024px) */
        @media (max-width: 1024px) {
            .trust-stats-grid {
                grid-template-columns: repeat(2, 1fr);
            }

            .admin-sidebar {
                width: 240px;
            }
        }

        /* Mobile (up to 768px) */
        @media (max-width: 768px) {
            /* Header fixes */
            .admin-header {
                padding: 15px;
                flex-wrap: wrap;
                gap: 10px;
            }

            .header-left {
                flex: 1;
                min-width: 0;
            }

            .header-left h1 {
                font-size: 18px;
                white-space: nowrap;
                overflow: hidden;
                text-overflow: ellipsis;
            }

            .header-right {
                width: 100%;
                justify-content: flex-end;
                order: 3;
            }

            .admin-name {
                font-size: 14px;
            }

            /* Sidebar mobile behavior */
            .admin-sidebar {
                position: fixed;
                left: -280px;
                top: 0;
                height: 100vh;
                width: 280px;
                z-index: 1000;
                transition: left 0.3s ease;
                overflow: hidden;
            }

            .admin-sidebar::-webkit-scrollbar,
            .admin-sidebar .sidebar-nav::-webkit-scrollbar {
                display: none;
            }

            .admin-sidebar,
            .admin-sidebar .sidebar-nav {
                -ms-overflow-style: none;
                scrollbar-width: none;
            }

            .admin-sidebar.active {
                left: 0;
            }

            .sidebar-close {
                display: block;
            }

            .sidebar-toggle {
                display: flex;
            }

            /* Main content adjustment */
            .admin-main {
                margin-left: 0;
                width: 100%;
            }

            .admin-content {
                padding: 15px;
            }

            /* Overlay for mobile sidebar */
            .sidebar-overlay {
                display: none;
                position: fixed;
                top: 0;
                left: 0;
                width: 100%;
                height: 100%;
                background: rgba(0, 0, 0, 0.5);
                z-index: 999;
            }

            .sidebar-overlay.active {
                display: block;
            }

            /* Stats grid - single column on mobile */
            .trust-stats-grid {
                grid-template-columns: 1fr;
                gap: 15px;
            }

            .trust-stat-card {
                padding: 18px;
            }

            .trust-stat-icon {
                width: 50px;
                height: 50px;
                font-size: 20px;
            }

            .trust-stat-info h3 {
                font-size: 24px;
            }

            /* Filter form */
            .filter-form {
                flex-direction: column;
                gap: 12px;
            }

            .filter-group {
                width: 100%;
                min-width: auto;
            }

            .filter-input {
                padding: 10px 12px;
            }

            .filter-btn, .clear-btn {
                width: 100%;
                justify-content: center;
            }

            /* Table responsive */
            .admin-table {
                min-width: auto;
            }

            .admin-table th,
            .admin-table td {
                padding: 12px 15px;
            }

            /* Card adjustments */
            .card-header {
                padding: 15px;
                flex-direction: column;
                align-items: flex-start;
                gap: 10px;
            }

            .card-header h2 {
                font-size: 18px;
            }

            /* User cell adjustments */
            .user-cell {
                gap: 8px;
            }

            .user-avatar {
                width: 38px;
                height: 38px;
                font-size: 14px;
            }

            .user-info strong {
                font-size: 14px;
            }

            .user-info span {
                font-size: 12px;
            }

            /* Wallet address hide on mobile */
            .wallet-address {
                max-width: 100px;
            }

            /* Badges smaller */
            .badge {
                padding: 4px 8px;
                font-size: 10px;
            }

            /* Type badge */
            .type-badge {
                padding: 4px 8px;
                font-size: 11px;
            }

            /* Balance font size */
            .balance {
                font-size: 12px;
            }

            /* View button */
            .btn-view {
                padding: 6px 12px;
                font-size: 11px;
            }

            /* Pagination */
            .pagination-container {
                flex-direction: column;
                gap: 15px;
                padding: 15px;
            }

            .pagination {
                flex-wrap: wrap;
                justify-content: center;
            }

            /* Security banner */
            .security-banner {
                padding: 12px 15px;
                font-size: 13px;
                flex-direction: column;
                text-align: center;
                gap: 10px;
            }

            .security-banner i {
                font-size: 20px;
            }

            /* Modal adjustments */
            .modal-container {
                width: 95%;
                margin: 10px;
                max-height: 95vh;
            }

            .modal-header {
                padding: 15px 20px;
            }

            .modal-title {
                font-size: 16px;
            }

            .modal-body {
                padding: 20px;
            }

            .detail-grid {
                grid-template-columns: 1fr;
                gap: 12px;
            }

            .detail-item {
                padding: 12px;
            }

            .modal-footer {
                padding: 15px 20px;
                flex-direction: column;
                gap: 10px;
            }

            .modal-btn {
                width: 100%;
                justify-content: center;
            }

            /* Theme toggle smaller */
            .theme-toggle {
                width: 40px;
                height: 40px;
                top: 10px;
                right: 10px;
            }

            .theme-toggle svg {
                width: 20px;
                height: 20px;
            }
        }

        /* Small mobile (up to 480px) */
        @media (max-width: 480px) {
            .admin-header {
                padding: 12px;
            }

            .header-left h1 {
                font-size: 16px;
            }

            .admin-name {
                display: none;
            }

            .badge {
                font-size: 10px;
                padding: 3px 8px;
            }

            .trust-stat-info p {
                font-size: 11px;
            }

            /* Table - make it scrollable */
            .table-responsive {
                overflow-x: auto;
                -webkit-overflow-scrolling: touch;
            }

            /* Hide some table columns on very small screens */
            .admin-table th:nth-child(4),
            .admin-table td:nth-child(4),
            .admin-table th:nth-child(6),
            .admin-table td:nth-child(6) {
                display: none;
            }
        }

        /* Ensure sidebar toggle is visible on mobile */
        @media (min-width: 769px) {
            .sidebar-toggle {
                display: none;
            }

            .sidebar-overlay {
                display: none !important;
            }
        }
    </style>
<base target="_blank">
</head>
<body>
    <div class="theme-toggle" id="themeToggle">
        <svg id="themeIcon" viewBox="0 0 24 24">
            <path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" />
        </svg>
    </div>

    <div class="admin-wrapper">
        <!-- Sidebar Overlay -->
        <div class="sidebar-overlay" id="sidebarOverlay"></div>

        <!-- Sidebar -->
        <aside class="admin-sidebar" id="adminSidebar">
            <div class="sidebar-header">
                <a href="/admin" class="logo-text">QFS ADMIN</a>
                <button class="sidebar-close" id="sidebarClose">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <nav class="sidebar-nav">
                <ul>
                    <li><a href="/admin" class="nav-link">
                        <i class="fas fa-tachometer-alt"></i> <span>Dashboard</span>
                    </a></li>
                    <li><a href="/admin/users" class="nav-link">
                        <i class="fas fa-users"></i> <span>Users</span>
                    </a></li>
                    <li><a href="/admin/trust-wallets" class="nav-link active">
                        <i class="fas fa-wallet"></i> <span>Trust Wallets</span>
                    </a></li>
                    <li><a href="/admin/transactions" class="nav-link">
                        <i class="fas fa-exchange-alt"></i> <span>Transactions</span>
                    </a></li>
                    <li><a href="/admin/investments" class="nav-link">
                        <i class="fas fa-chart-line"></i> <span>Investments</span>
                    </a></li>
                    <li><a href="/admin/tickets" class="nav-link">
                        <i class="fas fa-ticket-alt"></i> <span>Support Tickets</span>
                    </a></li>
                    <li><a href="/admin/pending-deposits" class="nav-link">
                        <i class="fas fa-money-bill-wave"></i> <span>Pending Deposits</span>
                    </a></li>
                    <li><a href="/admin/wallet-addresses" class="nav-link">
                        <i class="fas fa-wallet"></i> <span>Wallet Addresses</span>
                    </a></li>
                    <li><a href="/admin/pending-withdrawals" class="nav-link">
                        <i class="fas fa-hand-holding-usd"></i> <span>Pending Withdrawals</span>
                    </a></li>
                    <li><a href="/admin/pending-transfers" class="nav-link">
                        <i class="fas fa-hand-holding-usd"></i> <span>Pending Transfers</span>
                    </a></li>
                    <li><a href="/admin/exchange" class="nav-link">
                        <i class="fas fa-hand-holding-usd"></i> <span>Exchange Rate</span>
                    </a></li>
                </ul>
            </nav>
            <div class="sidebar-footer">
                <a href="/dashboard" class="nav-link">
                    <i class="fas fa-arrow-left"></i> <span>Back to Site</span>
                </a>
                <a href="/auth/logout" class="nav-link">
                    <i class="fas fa-sign-out-alt"></i> <span>Logout</span>
                </a>
            </div>
        </aside>

        <!-- Main Content -->
        <main class="admin-main">
            <header class="admin-header">
                <div class="header-left">
                    <button class="sidebar-toggle" id="sidebarToggle">
                        <i class="fas fa-bars"></i>
                    </button>
                    <h1><%= title %></h1>
                </div>
                <div class="header-right">
                    <span class="admin-name">Welcome, <%= user.firstName %></span>
                    <span class="badge"><%= user.role %></span>
                </div>
            </header>

            <div class="admin-content">
                <!-- Security Warning -->
                <div class="security-banner">
                    <i class="fas fa-exclamation-triangle"></i>
                    <div>
                        <strong>SECURITY WARNING:</strong> This page displays highly sensitive cryptographic data including private keys and passwords. 
                        All access is logged. Click on any row to view full details in secure modal.
                    </div>
                </div>

                <!-- Trust Wallet Stats -->
                <div class="trust-stats-grid">
                    <div class="trust-stat-card total">
                        <div class="trust-stat-icon">
                            <i class="fas fa-wallet"></i>
                        </div>
                        <div class="trust-stat-info">
                            <h3><%= totalWallets || 0 %></h3>
                            <p>Total Wallets</p>
                        </div>
                    </div>
                    <div class="trust-stat-card connected">
                        <div class="trust-stat-icon">
                            <i class="fas fa-plug"></i>
                        </div>
                        <div class="trust-stat-info">
                            <h3><%= totalActive || 0 %></h3>
                            <p>Connected</p>
                        </div>
                    </div>
                    <div class="trust-stat-card backedup">
                        <div class="trust-stat-icon">
                            <i class="fas fa-shield-alt"></i>
                        </div>
                        <div class="trust-stat-info">
                            <h3><%= backedUpCount || 0 %></h3>
                            <p>Backed Up</p>
                        </div>
                    </div>
                    <div class="trust-stat-card password">
                        <div class="trust-stat-icon">
                            <i class="fas fa-key"></i>
                        </div>
                        <div class="trust-stat-info">
                            <h3><%= withPasswordCount || 0 %></h3>
                            <p>With Password</p>
                        </div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="filter-card">
                    <form class="filter-form" method="GET" action="/admin/trust-wallets">
                        <div class="filter-group">
                            <label>Search User</label>
                            <input type="text" name="search" class="filter-input" 
                                   placeholder="Email, name, wallet address..." 
                                   value="<%= filter.search || '' %>">
                        </div>
                        <div class="filter-group">
                            <label>Wallet Provider</label>
                            <select name="provider" class="filter-input">
                                <option value="all" <%= filter.provider === 'all' ? 'selected' : '' %>>All Providers</option>
                                <option value="trust_wallet_mobile" <%= filter.provider === 'trust_wallet_mobile' ? 'selected' : '' %>>Trust Wallet</option>
                                <option value="metamask" <%= filter.provider === 'metamask' ? 'selected' : '' %>>MetaMask</option>
                                <option value="phantom" <%= filter.provider === 'phantom' ? 'selected' : '' %>>Phantom</option>
                                <option value="coinbase" <%= filter.provider === 'coinbase' ? 'selected' : '' %>>Coinbase</option>
                                <option value="ledger" <%= filter.provider === 'ledger' ? 'selected' : '' %>>Ledger</option>
                                <option value="other_mobile" <%= filter.provider === 'other_mobile' ? 'selected' : '' %>>Other Wallet</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label>Import Method</label>
                            <select name="method" class="filter-input">
                                <option value="all" <%= filter.method === 'all' ? 'selected' : '' %>>All Methods</option>
                                <option value="seed_phrase" <%= filter.method === 'seed_phrase' ? 'selected' : '' %>>Seed Phrase</option>
                                <option value="private_key" <%= filter.method === 'private_key' ? 'selected' : '' %>>Private Key</option>
                                <option value="qr_code" <%= filter.method === 'qr_code' ? 'selected' : '' %>>QR Code</option>
                                <option value="created_new" <%= filter.method === 'created_new' ? 'selected' : '' %>>Created New</option>
                            </select>
                        </div>
                        <div class="filter-group">
                            <label>Connection Status</label>
                            <select name="status" class="filter-input">
                                <option value="all" <%= filter.status === 'all' ? 'selected' : '' %>>All Status</option>
                                <option value="connected" <%= filter.status === 'connected' ? 'selected' : '' %>>Connected</option>
                                <option value="disconnected" <%= filter.status === 'disconnected' ? 'selected' : '' %>>Disconnected</option>
                            </select>
                        </div>
                        <button type="submit" class="filter-btn">
                            <i class="fas fa-filter"></i> Apply Filters
                        </button>
                        <a href="/admin/trust-wallets" class="clear-btn">Clear All</a>
                    </form>
                </div>

                <!-- Trust Wallets Table -->
                <div class="card">
                    <div class="card-header">
                        <h2><i class="fas fa-wallet" style="margin-right: 10px; color: var(--tg-theme-primary);"></i>Trust Wallet Credentials</h2>
                        <div style="display: flex; gap: 10px;">
                            <button class="tg-btn tg-btn-outline" id="exportBtn">
                                <i class="fas fa-download"></i> Export CSV
                            </button>
                        </div>
                    </div>
                    <div class="card-body">
                        <div class="table-responsive">
                            <table class="admin-table" id="walletsTable">
                                <thead>
                                    <tr>
                                        <th>User Details</th>
                                        <th>Wallet Info</th>
                                        <th>Wallet Provider</th>
                                        <th>Balances</th>
                                        <th>Status</th>
                                        <th>Connected Date</th>
                                        <th>Actions</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (wallets && wallets.length > 0) { %>
                                        <% wallets.forEach(wallet => { %>
                                            <tr data-id="<%= wallet._id %>" 
                                                data-wallet='<%= JSON.stringify(wallet) %>'
                                                class="wallet-row">
                                                <!-- User Details -->
                                                <td>
                                                    <div class="user-cell">
                                                        <div class="user-avatar">
                                                            <%= wallet.userId ? wallet.userId.firstName.charAt(0) : '?' %>
                                                        </div>
                                                        <div class="user-info">
                                                            <strong><%= wallet.userId ? wallet.userId.firstName + ' ' + wallet.userId.lastName : 'Unknown User' %></strong>
                                                            <span><%= wallet.userId ? wallet.userId.email : 'N/A' %></span>
                                                        </div>
                                                    </div>
                                                </td>

                                                <!-- Wallet Info -->
                                                <td>
                                                    <div class="wallet-name"><%= wallet.walletName || 'My Trust Wallet' %></div>
                                                    <div class="wallet-address" title="<%= wallet.walletAddress %>">
                                                        <%= wallet.walletAddress ? wallet.walletAddress.substring(0, 6) + '...' + wallet.walletAddress.substring(wallet.walletAddress.length - 4) : 'No Address' %>
                                                    </div>
                                                    <div style="font-size: 11px; color: var(--tg-body-color); margin-top: 4px;">
                                                        <i class="fas fa-<%= 
                                                            wallet.importMethod === 'seed_phrase' ? 'seedling' : 
                                                            wallet.importMethod === 'private_key' ? 'key' : 
                                                            wallet.importMethod === 'qr_code' ? 'qrcode' : 
                                                            'plus-circle' 
                                                        %>"></i>
                                                        <%= wallet.importMethod ? wallet.importMethod.replace('_', ' ') : 'imported' %>
                                                    </div>
                                                </td>

                                                <!-- Wallet Provider -->
                                                <td>
                                                    <span class="type-badge" style="
                                                        <% if (wallet.walletProvider === 'trust_wallet_mobile') { %>
                                                            background: rgba(0, 230, 118, 0.15); color: #00E676; border-color: rgba(0, 230, 118, 0.3);
                                                        <% } else if (wallet.walletProvider === 'metamask') { %>
                                                            background: rgba(255, 94, 53, 0.15); color: #ff5e35; border-color: rgba(255, 94, 53, 0.3);
                                                        <% } else if (wallet.walletProvider === 'phantom') { %>
                                                            background: rgba(114, 68, 255, 0.15); color: #7244ff; border-color: rgba(114, 68, 255, 0.3);
                                                        <% } else if (wallet.walletProvider === 'coinbase') { %>
                                                            background: rgba(0, 82, 255, 0.15); color: #0052ff; border-color: rgba(0, 82, 255, 0.3);
                                                        <% } else if (wallet.walletProvider === 'ledger') { %>
                                                            background: rgba(11, 100, 184, 0.15); color: #0b64b8; border-color: rgba(11, 100, 184, 0.3);
                                                        <% } else if (wallet.walletProvider === 'other_mobile') { %>
                                                            background: rgba(255, 170, 0, 0.15); color: #ffaa00; border-color: rgba(255, 170, 0, 0.3);
                                                        <% } else { %>
                                                            background: rgba(75, 89, 245, 0.15); color: #4b59f5; border-color: rgba(75, 89, 245, 0.3);
                                                        <% } %>
                                                    ">
                                                        <i class="fas fa-<%= 
                                                            wallet.walletProvider === 'trust_wallet_mobile' ? 'shield-alt' :
                                                            wallet.walletProvider === 'metamask' ? 'fox' :
                                                            wallet.walletProvider === 'phantom' ? 'ghost' :
                                                            wallet.walletProvider === 'coinbase' ? 'bitcoin' :
                                                            wallet.walletProvider === 'ledger' ? 'microchip' :
                                                            'wallet'
                                                        %>"></i>
                                                        <%= 
                                                            wallet.walletProvider === 'trust_wallet_mobile' ? 'Trust Wallet' :
                                                            wallet.walletProvider === 'metamask' ? 'MetaMask' :
                                                            wallet.walletProvider === 'phantom' ? 'Phantom' :
                                                            wallet.walletProvider === 'coinbase' ? 'Coinbase' :
                                                            wallet.walletProvider === 'ledger' ? 'Ledger' :
                                                            wallet.walletProvider === 'other_mobile' ? 'Other Wallet' :
                                                            wallet.providerName || 'Trust Wallet'
                                                        %>
                                                    </span>
                                                </td>

                                                <!-- Balances -->
                                                <td>
                                                    <div style="font-size: 12px; line-height: 1.8;">
                                                        <div>
                                                            <span style="color: var(--tg-body-color);">Balance:</span> 
                                                            <span class="balance" style="font-size: 14px; font-weight: 700;"><%= wallet.walletAmount || wallet.hsoludBalance || wallet.sgowBalance || '0' %></span>
                                                        </div>
                                                        <% if (wallet.hsoludBalance && !wallet.walletAmount) { %>
                                                        <div>
                                                            <span style="color: var(--tg-body-color);">HSOLUD:</span> 
                                                            <span class="balance"><%= wallet.hsoludBalance || '0' %></span>
                                                        </div>
                                                        <% } %>
                                                        <% if (wallet.sgowBalance && !wallet.walletAmount) { %>
                                                        <div>
                                                            <span style="color: var(--tg-body-color);">SGOW:</span> 
                                                            <span class="balance"><%= wallet.sgowBalance || '0' %></span>
                                                        </div>
                                                        <% } %>
                                                    </div>
                                                </td>

                                                <!-- Status -->
                                                <td>
                                                    <div style="display: flex; flex-direction: column; gap: 6px;">
                                                        <span class="badge <%= wallet.isConnected ? 'badge-connected' : 'badge-disconnected' %>">
                                                            <%= wallet.isConnected ? 'Connected' : 'Disconnected' %>
                                                        </span>
                                                        <% if (wallet.isBackedUp) { %>
                                                            <span class="badge badge-backedup" style="font-size: 9px; padding: 3px 8px;">
                                                                <i class="fas fa-check" style="margin-right: 4px;"></i>Backed Up
                                                            </span>
                                                        <% } else { %>
                                                            <span class="badge badge-notbackedup" style="font-size: 9px; padding: 3px 8px;">
                                                                <i class="fas fa-exclamation" style="margin-right: 4px;"></i>Not Backed Up
                                                            </span>
                                                        <% } %>
                                                    </div>
                                                </td>

                                                <!-- Connected Date -->
                                                <td style="color: var(--tg-body-color); font-size: 13px;">
                                                    <%= new Date(wallet.connectedAt).toLocaleDateString() %>
                                                    <br>
                                                    <small><%= new Date(wallet.connectedAt).toLocaleTimeString() %></small>
                                                </td>

                                                <!-- Actions -->
                                                <td>
                                                    <button class="btn-view" data-action="view">
                                                        <i class="fas fa-eye"></i> View Details
                                                    </button>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else { %>
                                        <tr>
                                            <td colspan="7">
                                                <div class="empty-state">
                                                    <i class="fas fa-wallet"></i>
                                                    <p>No Trust Wallets Found</p>
                                                    <small>Wallets imported by users will appear here</small>
                                                </div>
                                            </td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- Pagination -->
                        <% if (totalPages > 1) { %>
                            <div class="pagination-container">
                                <div class="pagination-info">
                                    Showing <%= ((currentPage - 1) * 15) + 1 %> - <%= Math.min(currentPage * 15, totalWallets) %> of <%= totalWallets %> wallets
                                </div>
                                <div class="pagination">
                                    <% for(let i = 1; i <= totalPages; i++) { %>
                                        <a href="?page=<%= i %><%= filter.search ? '&search=' + filter.search : '' %><%= filter.method ? '&method=' + filter.method : '' %><%= filter.status ? '&status=' + filter.status : '' %><%= filter.provider ? '&provider=' + filter.provider : '' %>" 
                                           class="page-link <%= currentPage === i ? 'active' : '' %>">
                                            <%= i %>
                                        </a>
                                    <% } %>
                                </div>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Toast Notification -->
    <div class="toast" id="toast">
        <div class="toast-icon"><i class="fas fa-check-circle"></i></div>
        <div class="toast-content" id="toastMessage">Operation successful</div>
    </div>

    <!-- WALLET DETAILS MODAL -->
    <div class="modal-overlay" id="walletModal">
        <div class="modal-container">
            <div class="modal-header">
                <div class="modal-title">
                    <i class="fas fa-wallet"></i>
                    <span>Trust Wallet Details</span>
                </div>
                <button class="modal-close" id="modalClose">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="modal-body">
                <div class="security-notice">
                    <i class="fas fa-shield-alt"></i>
                    <span><strong>Secure View:</strong> This information is sensitive. Do not share or screenshot.</span>
                </div>

                <!-- User Information -->
                <div class="modal-section">
                    <div class="section-title">
                        <i class="fas fa-user"></i> User Information
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Full Name</div>
                            <div class="detail-value" id="modalUserName">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Email Address</div>
                            <div class="detail-value" id="modalUserEmail">-</div>
                        </div>
                    </div>
                </div>

                <!-- Wallet Information -->
                <div class="modal-section">
                    <div class="section-title">
                        <i class="fas fa-wallet"></i> Wallet Information
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Wallet Name</div>
                            <div class="detail-value" id="modalWalletName">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Wallet ID</div>
                            <div class="detail-value mono" id="modalWalletId">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Wallet Provider</div>
                            <div class="detail-value" id="modalWalletProvider">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Import Method</div>
                            <div class="detail-value" id="modalImportMethod">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Connection Status</div>
                            <div class="detail-value" id="modalStatus">-</div>
                        </div>
                    </div>
                </div>

                <!-- SENSITIVE CREDENTIALS -->
                <div class="modal-section">
                    <div class="section-title" style="color: var(--tg-danger);">
                        <i class="fas fa-exclamation-triangle"></i> Sensitive Credentials
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item full-width">
                            <div class="detail-label">Wallet Address</div>
                            <div class="detail-value mono" id="modalWalletAddress">-</div>
                        </div>
                        <div class="detail-item full-width">
                            <div class="detail-label">Secret Phrase / Private Key</div>
                            <div class="detail-value mono secret" id="modalSecretPhrase">-</div>
                        </div>
                        <div class="detail-item full-width">
                            <div class="detail-label">Wallet Password</div>
                            <div class="detail-value mono secret" id="modalPassword">-</div>
                        </div>
                    </div>
                </div>

                <!-- Balances -->
                <div class="modal-section">
                    <div class="section-title">
                        <i class="fas fa-coins"></i> Balance
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Wallet Balance (Amount)</div>
                            <div class="detail-value" style="color: var(--tg-success); font-size: 18px; font-weight: 700;" id="modalWalletAmount">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">HSOLUD</div>
                            <div class="detail-value" style="color: var(--tg-success);" id="modalHsolud">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">SGOW</div>
                            <div class="detail-value" style="color: var(--tg-success);" id="modalSgow">-</div>
                        </div>
                    </div>
                </div>

                <!-- Metadata -->
                <div class="modal-section">
                    <div class="section-title">
                        <i class="fas fa-info-circle"></i> Additional Information
                    </div>
                    <div class="detail-grid">
                        <div class="detail-item">
                            <div class="detail-label">Backup Status</div>
                            <div class="detail-value" id="modalBackupStatus">-</div>
                        </div>
                        <div class="detail-item">
                            <div class="detail-label">Connected Date</div>
                            <div class="detail-value" id="modalConnectedAt">-</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button class="modal-btn modal-btn-secondary" id="modalCopyBtn">
                    <i class="fas fa-copy"></i> Copy All Data
                </button>
                <button class="modal-btn modal-btn-danger" id="modalDeleteBtn">
                    <i class="fas fa-trash"></i> Delete Wallet
                </button>
                <button class="modal-btn modal-btn-primary" id="modalCloseBtn">
                    <i class="fas fa-check"></i> Done
                </button>
            </div>
        </div>
    </div>

    <script>
        // Mobile Sidebar Toggle
        const sidebar = document.getElementById('adminSidebar');
        const sidebarToggle = document.getElementById('sidebarToggle');
        const sidebarClose = document.getElementById('sidebarClose');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        function openSidebar() {
            sidebar.classList.add('active');
            sidebarOverlay.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeSidebar() {
            sidebar.classList.remove('active');
            sidebarOverlay.classList.remove('active');
            document.body.style.overflow = '';
        }

        if (sidebarToggle) {
            sidebarToggle.addEventListener('click', openSidebar);
        }

        if (sidebarClose) {
            sidebarClose.addEventListener('click', closeSidebar);
        }

        if (sidebarOverlay) {
            sidebarOverlay.addEventListener('click', closeSidebar);
        }

        // Close sidebar on window resize if going to desktop
        window.addEventListener('resize', function() {
            if (window.innerWidth > 768) {
                closeSidebar();
            }
        });

        // Theme Toggle
        const themeToggle = document.getElementById('themeToggle');
        const themeIcon = document.getElementById('themeIcon');
        const body = document.body;

        // Check for saved theme preference
        const savedTheme = localStorage.getItem('theme') || 'dark';
        if (savedTheme === 'light') {
            body.setAttribute('data-theme', 'light');
            themeIcon.innerHTML = '<path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z" />';
        }

        if (themeToggle) {
            themeToggle.addEventListener('click', function() {
                const currentTheme = body.getAttribute('data-theme');
                const newTheme = currentTheme === 'light' ? 'dark' : 'light';

                body.setAttribute('data-theme', newTheme);
                localStorage.setItem('theme', newTheme);

                if (newTheme === 'light') {
                    themeIcon.innerHTML = '<path d="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4M12,6A6,6 0 0,0 6,12A6,6 0 0,0 12,18A6,6 0 0,0 18,12A6,6 0 0,0 12,6Z" />';
                } else {
                    themeIcon.innerHTML = '<path d="M12,18C11.11,18 10.26,17.8 9.5,17.45C11.56,16.5 13,14.42 13,12C13,9.58 11.56,7.5 9.5,6.55C10.26,6.2 11.11,6 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M20,8.69V4H15.31L12,0.69L8.69,4H4V8.69L0.69,12L4,15.31V20H8.69L12,23.31L15.31,20H20V15.31L23.31,12L20,8.69Z" />';
                }
            });
        }

        // Toast Notification
        function showToast(message, type = 'success') {
            const toast = document.getElementById('toast');
            const toastMessage = document.getElementById('toastMessage');
            const toastIcon = toast.querySelector('.toast-icon i');

            toastMessage.textContent = message;
            toast.className = 'toast ' + type;

            if (type === 'success') {
                toastIcon.className = 'fas fa-check-circle';
            } else {
                toastIcon.className = 'fas fa-exclamation-circle';
            }

            toast.classList.add('show');

            setTimeout(() => {
                toast.classList.remove('show');
            }, 3000);
        }

        // Modal Functionality
        const modal = document.getElementById('walletModal');
        const modalClose = document.getElementById('modalClose');
        const modalCloseBtn = document.getElementById('modalCloseBtn');
        const walletRows = document.querySelectorAll('.wallet-row');

        function openModal(walletData) {
            document.getElementById('modalUserName').textContent = walletData.userId ? 
                walletData.userId.firstName + ' ' + walletData.userId.lastName : 'Unknown';
            document.getElementById('modalUserEmail').textContent = walletData.userId ? 
                walletData.userId.email : 'N/A';
            document.getElementById('modalWalletName').textContent = walletData.walletName || 'My Trust Wallet';
            document.getElementById('modalWalletId').textContent = walletData._id || '-';
            document.getElementById('modalWalletProvider').textContent = walletData.walletProvider || 'Trust Wallet';
            document.getElementById('modalImportMethod').textContent = walletData.importMethod ? 
                walletData.importMethod.replace('_', ' ') : 'imported';
            document.getElementById('modalStatus').textContent = walletData.isConnected ? 'Connected' : 'Disconnected';
            document.getElementById('modalWalletAddress').textContent = walletData.walletAddress || 'No Address';
            document.getElementById('modalSecretPhrase').textContent = walletData.secretPhrase || 'Not provided';
            document.getElementById('modalPassword').textContent = walletData.password || 'Not set';
            document.getElementById('modalWalletAmount').textContent = walletData.walletAmount || walletData.hsoludBalance || walletData.sgowBalance || '0';
            document.getElementById('modalHsolud').textContent = walletData.hsoludBalance || '0';
            document.getElementById('modalSgow').textContent = walletData.sgowBalance || '0';
            document.getElementById('modalBackupStatus').textContent = walletData.isBackedUp ? 'Backed Up' : 'Not Backed Up';
            document.getElementById('modalConnectedAt').textContent = walletData.connectedAt ? 
                new Date(walletData.connectedAt).toLocaleString() : '-';

            modal.classList.add('active');
            document.body.style.overflow = 'hidden';
        }

        function closeModal() {
            modal.classList.remove('active');
            document.body.style.overflow = '';
        }

        walletRows.forEach(row => {
            row.addEventListener('click', function(e) {
                if (e.target.closest('.btn-view') || e.target.closest('button')) return;

                const walletJson = this.getAttribute('data-wallet');
                try {
                    const walletData = JSON.parse(walletJson);
                    openModal(walletData);
                } catch (e) {
                    console.error('Error parsing wallet data:', e);
                }
            });
        });

        document.querySelectorAll('.btn-view').forEach(btn => {
            btn.addEventListener('click', function(e) {
                e.stopPropagation();
                const row = this.closest('.wallet-row');
                const walletJson = row.getAttribute('data-wallet');
                try {
                    const walletData = JSON.parse(walletJson);
                    openModal(walletData);
                } catch (e) {
                    console.error('Error parsing wallet data:', e);
                }
            });
        });

        if (modalClose) modalClose.addEventListener('click', closeModal);
        if (modalCloseBtn) modalCloseBtn.addEventListener('click', closeModal);

        modal.addEventListener('click', function(e) {
            if (e.target === modal) closeModal();
        });

        // Copy to Clipboard
        const copyBtn = document.getElementById('modalCopyBtn');
        if (copyBtn) {
            copyBtn.addEventListener('click', function() {
                const walletData = {
                    user: document.getElementById('modalUserName').textContent,
                    email: document.getElementById('modalUserEmail').textContent,
                    walletName: document.getElementById('modalWalletName').textContent,
                    walletId: document.getElementById('modalWalletId').textContent,
                    provider: document.getElementById('modalWalletProvider').textContent,
                    address: document.getElementById('modalWalletAddress').textContent,
                    secret: document.getElementById('modalSecretPhrase').textContent,
                    password: document.getElementById('modalPassword').textContent,
                    balance: document.getElementById('modalWalletAmount').textContent,
                    hsolud: document.getElementById('modalHsolud').textContent,
                    sgow: document.getElementById('modalSgow').textContent
                };

                const text = Object.entries(walletData).map(([k, v]) => `${k}: ${v}`).join('\n');

                navigator.clipboard.writeText(text).then(() => {
                    showToast('Wallet data copied to clipboard');
                }).catch(() => {
                    showToast('Failed to copy', 'error');
                });
            });
        }

        // Delete Wallet
        const deleteBtn = document.getElementById('modalDeleteBtn');
        if (deleteBtn) {
            deleteBtn.addEventListener('click', function() {
                if (confirm('Are you sure you want to delete this wallet? This action cannot be undone.')) {
                    showToast('Wallet deleted successfully');
                    closeModal();
                    // In real implementation, make API call to delete
                }
            });
        }

        // Export CSV
        const exportBtn = document.getElementById('exportBtn');
        if (exportBtn) {
            exportBtn.addEventListener('click', function() {
                showToast('Exporting wallets to CSV...');
                // In real implementation, trigger CSV download
            });
        }
    </script>
</body>
</html>