        /* Large Connect Wallet Button with Sliding Effects */
.download-btn {
    display: flex;
    align-items: center;
    gap: 20px;
    padding: 24px 40px;
    border: 3px solid var(--trust-blue);
    border-radius: 60px;
    text-decoration: none;
    color: var(--trust-blue);
    font-weight: 700;
    transition: all 0.4s cubic-bezier(0.68, -0.55, 0.265, 1.55);
    background: white;
    position: relative;
    overflow: hidden;
    z-index: 1;
}

/* Sliding background effect on hover */
.download-btn::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: var(--trust-blue);
    transition: left 0.4s ease-in-out;
    z-index: -1;
}

.download-btn:hover::before {
    left: 0;
}

.download-btn:hover {
    color: white;
    transform: scale(1.05);
    box-shadow: 0 10px 30px rgba(5, 0, 255, 0.3);
    border-color: var(--trust-blue);
}

/* Sliding icon effect */
.download-btn svg {
    width: 36px;
    height: 36px;
    transition: transform 0.3s ease;
}

.download-btn:hover svg {
    transform: translateX(8px);
}

/* Text styles */
.download-btn-text {
    display: flex;
    flex-direction: column;
    line-height: 1.2;
    text-align: left;
}

.download-btn-text span:first-child {
    font-size: 18px;
    opacity: 0.8;
    letter-spacing: 1px;
}

.download-btn-text span:last-child {
    font-size: 28px;
    font-weight: 800;
    letter-spacing: 1.5px;
}

/* Pulse animation on load */
@keyframes pulse {
    0% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(5, 0, 255, 0.4);
    }
    70% {
        transform: scale(1.02);
        box-shadow: 0 0 0 15px rgba(5, 0, 255, 0);
    }
    100% {
        transform: scale(1);
        box-shadow: 0 0 0 0 rgba(5, 0, 255, 0);
    }
}

.download-btn {
    animation: pulse 2s infinite;
}

/* Dark mode adjustments */
body.dark-mode .download-btn {
    border-color: var(--green-accent);
    color: var(--green-accent);
}

body.dark-mode .download-btn::before {
    background: var(--green-accent);
}

body.dark-mode .download-btn:hover {
    color: #000000;
    box-shadow: 0 10px 30px rgba(0, 230, 118, 0.3);
}

/* Optional: Shake effect on click */
.download-btn:active {
    transform: scale(0.98);
    transition: transform 0.1s;
}
